{
  "name": "packing-list-mobile-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "npx react-native start",
    "android": "npx react-native run-android",
    "android:dev": "./scripts/android-with-env.sh npx react-native run-android --active-arch-only",
    "android:apk:assemble-and-deploy": "./scripts/android-with-env.sh sh -c 'cd android && ./gradlew assembleRelease && cd .. && adb install android/app/build/outputs/apk/release/app-release.apk'",
    "android:apk:deploy": "./scripts/android-with-env.sh sh -c 'adb install android/app/build/outputs/apk/release/app-release.apk'",
    "ios": "npx react-native run-ios",
    "ios:rebuild": "cd ios && pod install && cd .. && npx react-native run-ios --simulator='iPhone 17'",
    "ios:simulator": "npx react-native run-ios --simulator='iPhone 17'",
    "ios:simulator:ipad": "npx react-native run-ios --simulator='iPad (A16)'",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "find-unused": "knip",
    "prebuild": "npm run typecheck && npm run lint && knip && npm run test:unit",
    "ios:release": "./scripts/ios-release.sh",
    "spaces:cleanup": "node scripts/cleanup-spaces.js",
    "spaces:migrate": "node scripts/migrate-to-spaces.js",
    "list:dev-servers": "lsof -i tcp -P -n | grep LISTEN | grep node | awk '{print $9}'",
    "list:dev-servers-port": "lsof -ti tcp:8081",
    "list:simulators": "xcrun simctl list devices available"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "firebase": "^11.0.2",
    "i18next": "^26.2.0",
    "react": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-localize": "^3.7.0",
    "react-native-navigation": "8.7.4",
    "react-native-purchases": "^9.10.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@biomejs/biome": "^2.3.13",
    "@react-native-community/cli": "^20.1.1",
    "@react-native-community/cli-platform-ios": "^20.1.1",
    "@react-native/metro-config": "^0.81.5",
    "@types/hoist-non-react-statics": "^3.3.7",
    "@types/lodash": "^4.17.23",
    "@types/prop-types": "^15.7.15",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-module-resolver": "^5.0.0",
    "firebase-admin": "^13.6.1",
    "knip": "^5.82.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2"
  }
}
