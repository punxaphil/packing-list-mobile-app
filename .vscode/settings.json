{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true,
    "source.fixAll": false,
    "source.organizeImports": false
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "prettier.enable": false,
  "files.exclude": {
    "node_modules": true,
    "ios": true,
    "android": true
  },
  "search.exclude": {
    "node_modules": true,
    "ios": true,
    "android": true
  }
}
